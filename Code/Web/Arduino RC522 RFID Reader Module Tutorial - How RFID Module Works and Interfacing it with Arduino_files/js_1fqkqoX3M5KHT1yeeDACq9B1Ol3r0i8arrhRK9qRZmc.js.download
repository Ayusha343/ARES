 (function ($) {
  var url2= window.location.href;
    if(url2=="https://circuitdigest.com/user/register/contest"){
        $('.breadcrumb').css({"display":"none"});
        $('h2').text('Participate in World Energy Challenge 2023 Contest'); 

    }
  var value2 = window.location.href.substring(window.location.href.lastIndexOf('/') + 1);
 // console.log(value2); console.log( value2.substr(0, 4));
  var value2 = value2.substring(0, 4);
    if(value2=="edit" && $('#edit-field-phone-no-0-value').length){
        $('#edit-field-project-idea-0-value').attr('disabled', 'disabled');
$('#edit-field-user-country')
    .empty()
    .append('<option value="Vanuatu">Vanuatu</option><option value="Brunei">Brunei</option><option value="Cambodia">Cambodia</option><option value="India">India</option><option value="Indonesia">Indonesia</option><option value="Laos">Laos</option><option value="Malaysia">Malaysia</option><option value="Myanmar">Myanmar</option><option value="Philippines">Philippines</option><option value="Singapore">Singapore</option><option value="Thailand">Thailand</option><option value="Vietnam">Vietnam</option>');
    $('#edit-field-user-country-wrapper').css('display','none');
    }  


  $('.seemore').hide();
  $('.show-more').show();

$('.show-more').on('click', function() {
  //toggle elements with class .ty-compact-list that their index is bigger than 2
  $('.seemore').toggle();
  //change text of show more element just for demonstration purposes to this demo
  $(this).text() === '...Show more' ? $(this).text('  Show less') : $(this).text('... Show more');
});

  if(url2=="https://circuitdigest.com/user/register"){
    $('.user-register-form #edit-field-participate-wrapper').css({"display":"none"});
  $(".user-register-form #edit-field-user-country").change(function() {
    var val = $(this).val();
    if(val === "Brunei" || val === "Cambodia" || val === "India" || val === "Indonesia" || val === "Laos" || val === "Malaysia" || val === "Myanmar" || val === "Philippines" || val === "Singapore" || val === "Thailand" || val === "Vietnam") {
        $(".user-register-form #edit-field-participate-wrapper").show();
    }
    else{
        $(".user-register-form #edit-field-participate-wrapper").hide();
    }
  });
}


