(function ($) {
  $(".btn-navbar").click(function(){
                if($("#tb-megamenu-main div").css('display') == 'none'){
                	$("#tb-megamenu-main div").css('display','block');
                	$("#tb-megamenu-main div").show;
                }
                              else if($("#tb-megamenu-main div").css('display') == 'block'){
                	$("#tb-megamenu-main div").css('display','none');
                	$("#tb-megamenu-main div").hide;
                }
  });

        $(".region-content .content .field--name-field-image img,.region-content .content .field--name-field-project-image img").each(function(){
          var title = this.alt;
          var widthc= this.width;
          $(this).after('<div class="imagecaption">'+ title +'</div>');
          $(".imagecaption").css({"width": widthc, "max-width": "100%"});
      }); //Adds the dynamic captions.

        $('.region-content .content .field--name-body p').each(function() {
        var $this = $(this);
        if($this.html().replace(/\s|&nbsp;/g, '').length == 0)
          $this.remove();
        });

        if( $('.region-content .content .field--name-field-code .field--item > pre').length == 0 ) {
        $(".region-content .content .field--name-field-code .field--item").wrapInner('<pre style="line-height:1;"></pre>');
      }
      $("#block-views-block-front-page-view-block-9 .views-field-field-image .field-content").wrapInner('<center></center>');

